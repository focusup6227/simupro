# Copy to `.env.local` and fill in values. Next.js loads `.env.local` automatically;
# it does NOT load `.env.example` (this file is only documentation / template).

# Supabase (browser + SSR)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: never expose to the browser or commit to git
SUPABASE_SERVICE_ROLE_KEY=

# Local / agent E2E: `npm run seed:test-users` (requires service role key above).
# Default password is in AGENTS.md unless you set:
# CURSOR_AGENT_TEST_PASSWORD=
# Allow seeding against non-local Supabase (staging only; never production):
# ALLOW_SEED_TEST_USERS=

# Genkit / Google AI
# Genkit uses GEMINI_API_KEY by default.
GEMINI_API_KEY=
# Backwards-compat (older configs)
GOOGLE_API_KEY=

# Stripe (Premium)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Optional: annual billing (add a yearly recurring Price in Stripe, then paste its ID here)
# STRIPE_PRICE_ID_ANNUAL=

# Optional: canonical site URL for checkout redirects
# NEXT_PUBLIC_SITE_ORIGIN=https://your-domain.com

# Sentry (optional — error monitoring; build source-map uploads need ORG + PROJECT + AUTH_TOKEN)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# Optional: disable service worker/PWA generation (recommended if SW cache causes stale chunks)
# DISABLE_PWA=true
